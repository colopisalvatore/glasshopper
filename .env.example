# Standalone dev mode: point Vite at your Home Assistant instance.
# Required only when running `npm run dev` outside the HA panel iframe.
VITE_HA_URL=http://homeassistant.local:8123

# Optional: override the asset base path used when building for the HA panel.
# The `npm run sync` script sets this automatically — do not set it manually
# unless you know what you're doing.
# VITE_BASE=/ha_react_ui_files/
