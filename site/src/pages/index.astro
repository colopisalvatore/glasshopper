---
const REPO = 'https://github.com/colopisalvatore/ha-react-ui';
const DOCS = 'https://docs.hareactui.dev';
const features = [
  {
    title: 'Native HA panels',
    body: 'Each dashboard lives in HA\'s sidebar like a built-in. HACS-installable, configurable from the UI, no panel_iframe YAML.',
  },
  {
    title: 'Zero-auth bridge',
    body: 'In panel mode the bundle inherits the WebSocket your HA frontend already has open. No tokens. No CORS. No reverse-proxy gymnastics.',
  },
  {
    title: 'Five hooks',
    body: 'useEntity. useService. useHistory. useArea. useTheme. The entire API surface fits on one screen.',
  },
  {
    title: 'Multi-dashboard',
    body: 'One install, many panels. Each with its own slug, sidebar icon, and admin gate. One bundle, many faces.',
  },
  {
    title: 'Standalone routes',
    body: 'Every dashboard has a /custom-dashboard/<slug>/ URL. Public-mode toggle for kiosks. PWA-installable from iOS.',
  },
  {
    title: 'Template ecosystem',
    body: 'Ship your dashboard as a zip. Users install via a single service call. Free or paid — your choice.',
  },
];
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>HA React UI — custom Home Assistant dashboards in React</title>
    <meta
      name="description"
      content="Build custom Home Assistant dashboards in React. Native sidebar panels, five hooks, zero auth setup."
    />
    <meta property="og:title" content="HA React UI" />
    <meta
      property="og:description"
      content="Build custom Home Assistant dashboards in React."
    />
    <meta property="og:type" content="website" />
    <link rel="canonical" href="https://hareactui.dev/" />
    <link
      rel="preconnect"
      href="https://rsms.me/"
      crossorigin
    />
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />
    <style is:global>
      :root {
        color-scheme: dark;
        --bg: #07070a;
        --fg: #f4f4f5;
        --muted: #a1a1aa;
        --accent: #60a5fa;
        --border: rgba(255, 255, 255, 0.08);
        --panel: rgba(255, 255, 255, 0.03);
      }
      * { box-sizing: border-box; }
      html, body {
        margin: 0;
        background: radial-gradient(circle at top, #14141c 0%, #07070a 60%);
        color: var(--fg);
        font-family: Inter, system-ui, -apple-system, Segoe UI, sans-serif;
        font-size: 16px;
        line-height: 1.55;
        font-feature-settings: "cv11", "ss03";
      }
      a { color: inherit; text-decoration: none; }
      code, pre {
        font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
      }
      main { max-width: 1080px; margin: 0 auto; padding: 0 24px; }
      .nav {
        display: flex; align-items: center; justify-content: space-between;
        padding: 24px 0; font-size: 14px;
      }
      .nav__brand { font-weight: 600; letter-spacing: -0.01em; }
      .nav__links { display: flex; gap: 24px; color: var(--muted); }
      .nav__links a:hover { color: var(--fg); }

      .hero { padding: 80px 0 60px; text-align: center; }
      .hero__eyebrow {
        display: inline-block; padding: 6px 14px; border-radius: 999px;
        border: 1px solid var(--border); font-size: 12px; color: var(--muted);
        margin-bottom: 24px;
      }
      .hero__title {
        font-size: clamp(36px, 6vw, 64px); font-weight: 600;
        line-height: 1.05; letter-spacing: -0.03em; margin: 0 0 24px;
      }
      .hero__title em {
        font-style: normal;
        background: linear-gradient(135deg, #60a5fa, #a78bfa);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
      }
      .hero__sub {
        font-size: 18px; color: var(--muted); max-width: 600px;
        margin: 0 auto 36px;
      }
      .hero__ctas { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
      .btn {
        display: inline-flex; align-items: center; gap: 8px;
        padding: 12px 22px; border-radius: 10px;
        font-size: 14px; font-weight: 500;
        border: 1px solid var(--border); cursor: pointer;
        transition: transform 0.15s ease, background 0.2s ease;
      }
      .btn:hover { transform: translateY(-1px); }
      .btn--primary { background: var(--fg); color: #0a0a0f; border-color: var(--fg); }
      .btn--secondary { background: var(--panel); color: var(--fg); }

      .snippet {
        background: #0d0d12; border: 1px solid var(--border);
        border-radius: 14px; padding: 24px; margin: 40px auto 0;
        max-width: 760px; text-align: left; overflow-x: auto;
      }
      .snippet pre { margin: 0; font-size: 13px; line-height: 1.7; }
      .snippet .k { color: #c4b5fd; }
      .snippet .s { color: #fcd34d; }
      .snippet .c { color: var(--muted); font-style: italic; }
      .snippet .f { color: #6ee7b7; }
      .snippet .v { color: #93c5fd; }

      .features {
        padding: 80px 0; display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 24px;
      }
      .feat {
        background: var(--panel); border: 1px solid var(--border);
        border-radius: 14px; padding: 22px;
      }
      .feat h3 { margin: 0 0 8px; font-size: 16px; font-weight: 500; }
      .feat p { margin: 0; font-size: 14px; color: var(--muted); }

      .install {
        padding: 60px 0; text-align: center;
        border-top: 1px solid var(--border);
      }
      .install h2 { font-size: 28px; margin: 0 0 24px; font-weight: 500; }
      .install pre {
        display: inline-block; padding: 16px 24px;
        background: #0d0d12; border: 1px solid var(--border);
        border-radius: 10px; margin: 0; font-size: 14px;
      }

      .footer {
        padding: 40px 0; text-align: center; color: var(--muted);
        font-size: 13px; border-top: 1px solid var(--border);
      }
      .footer a:hover { color: var(--fg); }
    </style>
  </head>
  <body>
    <main>
      <nav class="nav">
        <div class="nav__brand">HA React UI</div>
        <div class="nav__links">
          <a href={DOCS}>Docs</a>
          <a href={`${DOCS}/hooks/useEntity`}>Hooks</a>
          <a href={`${DOCS}/templates/`}>Templates</a>
          <a href={REPO}>GitHub</a>
        </div>
      </nav>

      <section class="hero">
        <span class="hero__eyebrow">v0.2 · Open source · Apache-2.0</span>
        <h1 class="hero__title">
          Custom Home Assistant<br />
          dashboards in <em>React</em>.
        </h1>
        <p class="hero__sub">
          Native sidebar panels. Inherits HA's session. Five hooks for state,
          services, history, areas, and theme. No tokens to manage, no CORS to
          fight, no panel_iframe boilerplate.
        </p>
        <div class="hero__ctas">
          <a class="btn btn--primary" href={`${DOCS}/guide/quickstart`}>Quickstart</a>
          <a class="btn btn--secondary" href={REPO}>★ Star on GitHub</a>
        </div>

        <div class="snippet">
          <pre><span class="c">// One npx away from a fresh dashboard.</span>
<span class="k">npx</span> create-ha-react-ui my-dashboard

<span class="c">// Five hooks. That's the whole API.</span>
<span class="k">import</span> &#123; <span class="f">useEntity</span>, <span class="f">useService</span> &#125; <span class="k">from</span> <span class="s">'@/hooks'</span>;

<span class="k">const</span> light = <span class="f">useEntity</span>(<span class="s">'light.kitchen'</span>);
<span class="k">const</span> turnOn = <span class="f">useService</span>(<span class="s">'light'</span>, <span class="s">'turn_on'</span>);

&lt;<span class="v">button</span> onClick=&#123;() =&gt; turnOn(&#123; entity_id: light.entity_id &#125;)&#125;&gt;
  &#123;light.state&#125;
&lt;/<span class="v">button</span>&gt;</pre>
        </div>
      </section>

      <section class="features">
        {features.map((f) => (
          <article class="feat">
            <h3>{f.title}</h3>
            <p>{f.body}</p>
          </article>
        ))}
      </section>

      <section class="install">
        <h2>Install via HACS</h2>
        <pre>{`Custom repository → ${REPO} → Integration`}</pre>
      </section>

      <footer class="footer">
        <p>
          <a href={REPO}>GitHub</a> · <a href={DOCS}>Docs</a> ·{' '}
          <a href={`${DOCS}/templates/jarvis`}>Jarvis premium</a>
        </p>
        <p>Apache-2.0 · © {new Date().getFullYear()} Salvatore Colopi</p>
      </footer>
    </main>
  </body>
</html>
